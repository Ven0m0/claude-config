{
  "mcpServers": {
    "github-mcp-server": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/x/all/insiders",
      "tools": ["*"],
      "headers": { "Authorization": "Bearer ${GITHUB_PERSONAL_ACCESS_TOKEN}" }
    },
    "sequential-thinking": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"],
      "tools": ["*"]
    },
    "exa": {
      "type": "http",
      "url": "https://mcp.exa.ai/mcp?tools=web_search_exa,web_search_advanced_exa,get_code_context_exa,crawling_exa",
      "tools": ["*"],
      "headers": { "EXA_API_KEY": "${EXA_API_KEY}" }
    },
    "ref-tools": {
      "type": "http",
      "url": "https://api.ref.tools/mcp",
      "tools": ["*"],
      "headers": { "x-ref-api-key": "${REF_API_KEY" }
    },
    "grep-app": {
      "type": "http",
      "url": "https://mcp.grep.app",
      "tools": ["*"]
    },
    "serena": {
      "type": "local",
      "tools": ["*"],
      "command": "uvx",
      "args": ["--from", "git+https://github.com/oraios/serena", "serena", "start-mcp-server", "--project-from-cwd"]
    },
    "morph-mcp": {
      "type": "local",
      "tools": ["*"],
      "command": "npx",
      "args": ["-y", "@morphllm/morphmcp"],
      "env": { "MORPH_API_KEY": "${MORPH_API_KEY}" }
    }
  }
}
