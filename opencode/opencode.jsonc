{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["AGENTS.md", "CLAUDE.md", "copilot-instructions.md", "~/.config/opencode/node_modules/opencode-morph-fast-apply/instructions/morph-tools.md"],
  "plugin": [
    "github:JRedeker/opencode-morph-fast-apply",
    "@zenobius/opencode-skillful@latest",
    "@spoons-and-mirrors/subtask2@latest",
    "@ramarivera/opencode-model-announcer@latest",
    "opencode-pty@latest",
    "opencode-antigravity-auth@latest",
    "opencode-gemini-auth@latest",
    "opencode-anthropic-auth@latest",
    "opencode-copilot-auth@latest",
    "opencode-cursor-auth@latest",
    "opencode-kilo-auth@latest",
    "@mathew-cf/opencode-mcp-auto-reauth@latest",
    "opencode-ignore@latest",
    "opencode-agent-skills@latest",
    "opencode-agent-memory@latest",
    "@zenobius/opencode-background@latest",
    "@tarquinen/opencode-dcp@latest",
    "opencode-morphllm@latest",
    "opencode-plugin-preload-skills@latest",
    "opencode-gitbutler@latest",
    "opencode-blocker-diverter@latest",
    "opencode-session-handoff@latest",
    "opencode-image-compress@latest",
    "opentmux@latest",
    "opencode-repos@latest",
    "opencode-plugin-auto-update@latest",
    "opencode-websearch@latest",
    "opencode-ralph-loop@latest",
    "openslimedit@latest",
    "better-opencode-async-agents@latest",
    "everything-opencode@latest",
    "@bastiangx/opencode-unmoji@latest",
    "opencode-lazy-loader@latest",
    "@old-mikser/occontext-thinking-trim@latest",
    "@tuanhung303/opencode-acp@latest",
    "opencode-codebase-index@latest",
    "context-mode@latest",
    "opencode-cachebro@latest",
    "opencode-dir@latest",
    "opencode-fastedit@latest",
    "opencode-fast-apply@latest",
    "agentsync@latest",
    "cachebro@latest",
    "tailcode@latest",
    "oh-my-opencode-slim@latest",
    "opencode-plugin-search"
  ],
  "agent": {
    "explore": {
      "permission": {
        "edit": "deny",
        "write": "deny",
        "bash": {
          "*": "deny",
          "ls *": "allow",
          "tree *": "allow",
          "cat *": "allow",
          "head *": "allow",
          "tail *": "allow",
          "grep *": "allow",
          "rg *": "allow",
          "find *": "allow",
          "git *": "allow"
        }
      }
    },
    "general": {
      "disable": false
    },
    "researcher": {
      "permission": {
        "context7_*": "allow",
        "exa_*": "allow",
        "gh_grep_*": "allow",
        "webfetch": "allow",
        "write": "deny",
        "edit": "deny",
        "bash": {
          "*": "deny",
          "gh *": "allow",
          "npm view*": "allow",
          "pip show*": "allow",
          "man *": "allow",
          "jq *": "allow",
          "grep *": "allow",
          "rg *": "allow"
        }
      }
    },
    "scribe": {
      "permission": {
        "bash": {
          "*": "deny"
        },
        "edit": "allow",
        "glob": "allow",
        "read": "allow",
        "write": "allow"
      }
    },
    "coder": {
      "permission": {
        "context7_*": "deny",
        "exa_*": "deny",
        "gh_grep_*": "deny",
        "read": "allow",
        "write": "allow",
        "edit": "allow",
        "glob": "allow",
        "grep": "allow",
        "bash": "allow"
      }
    },
    "reviewer": {
      "temperature": 0.2,
      "permission": {
        "edit": "deny",
        "write": "deny",
        "bash": {
          "*": "deny",
          "git diff*": "allow",
          "git log*": "allow",
          "git show*": "allow",
          "git blame*": "allow",
          "rg *": "allow"
        },
        "plan_read": "allow",
        "delegation_read": "allow",
        "delegation_list": "allow"
      }
    },
    "plan": {
      "permission": {
        "edit": "deny",
        "write": "deny",
        "bash": {
          "*": "deny"
        },
        "task": "allow",
        "worktree_*": "allow"
      }
    },
    "build": {
      "permission": {
        "edit": "deny",
        "write": "deny",
        "bash": {
          "*": "deny"
        },
        "task": "allow",
        "worktree_*": "allow"
      }
    }
  },
  "mcp": {
    "MCP_DOCKER": {
      "type": "local",
      "command": ["docker", "mcp", "gateway", "run"],
      "enabled": true
    }
  },
  "provider": {
    "zai-coding-plan": {
      "options": {
        "apiKey": "$Z_AI_API_KEY"
      }
    },
    "cursor": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Cursor Agent",
      "options": {
        "baseURL": "http://127.0.0.1:32123/v1"
      },
      "models": {
        "auto": {
          "name": "Cursor Auto"
        },
        "gpt-5": {
          "name": "GPT-5 (-> gpt-5.2)"
        },
        "gpt-5.2": {
          "name": "GPT-5.2"
        },
        "gpt-5.1": {
          "name": "GPT-5.1"
        },
        "gpt-5.1-codex": {
          "name": "GPT-5.1 Codex"
        },
        "opus-4.6": {
          "name": "Claude Opus 4.6"
        },
        "opus-4.5": {
          "name": "Claude Opus 4.5"
        },
        "sonnet-4": {
          "name": "Claude Sonnet 4 (-> 4.5)"
        },
        "sonnet-4.5": {
          "name": "Claude Sonnet 4.5"
        },
        "sonnet-4.5-thinking": {
          "name": "Claude Sonnet 4.5 Thinking"
        }
      }
    },
    "google": {
      "models": {
        "antigravity-gemini-3-pro": {
          "name": "Gemini 3 Pro (Antigravity)",
          "limit": {
            "context": 1048576,
            "output": 65535
          },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"]
          },
          "variants": {
            "low": {
              "thinkingLevel": "low"
            },
            "high": {
              "thinkingLevel": "high"
            }
          }
        },
        "antigravity-gemini-3-flash": {
          "name": "Gemini 3 Flash (Antigravity)",
          "limit": {
            "context": 1048576,
            "output": 65536
          },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"]
          },
          "variants": {
            "minimal": {
              "thinkingLevel": "minimal"
            },
            "low": {
              "thinkingLevel": "low"
            },
            "medium": {
              "thinkingLevel": "medium"
            },
            "high": {
              "thinkingLevel": "high"
            }
          }
        },
        "antigravity-claude-sonnet-4-5": {
          "name": "Claude Sonnet 4.5 (Antigravity)",
          "limit": {
            "context": 200000,
            "output": 64000
          },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"]
          }
        },
        "antigravity-claude-sonnet-4-5-thinking": {
          "name": "Claude Sonnet 4.5 Thinking (Antigravity)",
          "limit": {
            "context": 200000,
            "output": 64000
          },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"]
          },
          "variants": {
            "low": {
              "thinkingConfig": {
                "thinkingBudget": 8192
              }
            },
            "max": {
              "thinkingConfig": {
                "thinkingBudget": 32768
              }
            }
          }
        },
        "antigravity-claude-opus-4-5-thinking": {
          "name": "Claude Opus 4.5 Thinking (Antigravity)",
          "limit": {
            "context": 200000,
            "output": 64000
          },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"]
          },
          "variants": {
            "low": {
              "thinkingConfig": {
                "thinkingBudget": 8192
              }
            },
            "max": {
              "thinkingConfig": {
                "thinkingBudget": 32768
              }
            }
          }
        },
        "gemini-2.5-flash": {
          "name": "Gemini 2.5 Flash (Gemini CLI)",
          "limit": {
            "context": 1048576,
            "output": 65536
          },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"]
          }
        },
        "gemini-2.5-pro": {
          "name": "Gemini 2.5 Pro (Gemini CLI)",
          "limit": {
            "context": 1048576,
            "output": 65536
          },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"]
          }
        },
        "gemini-3-flash-preview": {
          "name": "Gemini 3 Flash Preview (Gemini CLI)",
          "limit": {
            "context": 1048576,
            "output": 65536
          },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"]
          }
        },
        "gemini-3-pro-preview": {
          "name": "Gemini 3 Pro Preview (Gemini CLI)",
          "limit": {
            "context": 1048576,
            "output": 65535
          },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"]
          }
        }
      }
    }
  },
  "model": "zai-coding-plan/glm-4.7",
  "small_model": "zai-coding-plan/glm-4.5-air",
  "permission": {
    "bash": "allow",
    "task": "deny",
    "context7_*": "allow",
    "exa_*": "allow",
    "gh_grep_*": "allow",
    "kagi_*": "allow",
    "webfetch": "allow",
    "worktree_*": "allow",
    "lsp": "allow",
    "skill": "allow",
    "question": "allow"
  }
}
