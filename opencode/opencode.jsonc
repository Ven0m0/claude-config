{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "AGENTS.md",
    "../.github/copilot-instructions.md",
    "MORPH_INSTRUCTIONS.md"
  ],
  // Lean plugin set: one Morph path, one orchestration layer, trimmed auth,
  // and no broken Bun-only context plugin until upstream compatibility lands.
  "plugin": [
    // Editing and terminal UX
    "@morphllm/opencode-morph-plugin@2.0.7",
    "opencode-pty@latest",

    // Auth and session continuity
    "opencode-anthropic-oauth",
    "opencode-antigravity-auth@latest",
    "opencode-gemini-auth@latest",
    "opencode-session-handoff@latest",

    // Safety and quality-of-life
    "opencode-image-compress@latest",
    "opencode-websearch@latest",
    "opencode-ignore@latest",
    # TODO: replace with better alternative
    # "oh-my-opencode@latest",
    // Added intentionally for Flow-based planning/review workflows.
    "github:gmickel/flow-next-opencode#276713a0d61b01d6356f79ec937d97cd8d39a039"
  ],
  "lsp": {
    "typescript": {
      "command": ["typescript-language-server", "--stdio"],
      "extensions": [
        ".js",
        ".jsx",
        ".ts",
        ".tsx",
        ".mjs",
        ".cjs",
        ".mts",
        ".cts"
      ],
      "initialization": {
        "preferences": {
          "importModuleSpecifierPreference": "relative"
        }
      }
    },
    "pyright": {
      "command": ["pyright-langserver", "--stdio"],
      "extensions": [".py", ".pyw", ".pyi"]
    },
    "rust": {
      "command": [
        "/home/ven0m0/.rustup/toolchains/nightly-x86_64-unknown-linux-gnu/bin/rust-analyzer"
      ],
      "extensions": [".rs"]
    },
    "bash": {
      "command": ["bash-language-server", "start"],
      "extensions": [".sh", ".bash", ".zsh"]
    },
    "yaml-ls": {
      "command": ["yaml-language-server", "--stdio"],
      "extensions": [".yaml", ".yml"]
    }
  },
  "formatter": {
    "prettier": {
      "command": ["prettier", "--write", "$FILE"],
      "extensions": [
        ".js",
        ".jsx",
        ".ts",
        ".tsx",
        ".json",
        ".jsonc",
        ".md",
        ".css",
        ".scss",
        ".html",
        ".yml",
        ".yaml"
      ]
    },
    "ruff": {
      "command": ["uv", "tool", "run", "ruff", "format", "$FILE"],
      "extensions": [".py", ".pyw", ".pyi"]
    },
    "rustfmt": {
      "command": [
        "/home/ven0m0/.rustup/toolchains/nightly-x86_64-unknown-linux-gnu/bin/rustfmt",
        "$FILE"
      ],
      "extensions": [".rs"]
    },
    "shfmt": {
      "command": ["shfmt", "-w", "$FILE"],
      "extensions": [".sh", ".bash", ".zsh"]
    }
  },
  "agent": {
    "explore": {
      "model": "minimax/MiniMax-M2.5",
      "permission": {
        "edit": "deny",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "write": "deny",
        "bash": {
          "*": "deny",
          "ls *": "allow",
          "eza *": "allow",
          "tree *": "allow",
          "rg *": "allow",
          "fd *": "allow",
          "git *": "allow"
        }
      }
    },
    "executor": {
      "model": "minimax/MiniMax-M2.7",
      "permission": {
        "context7_*": "deny",
        "exa_*": "deny",
        "gh_grep_*": "deny",
        "read": "allow",
        "write": "allow",
        "edit": "allow",
        "glob": "allow",
        "grep": "allow",
        "bash": "allow",
        "task": "deny"
      }
    },
    "general": {
      "disable": false
    },
    "researcher": {
      "model": "google/gemini-3.1-pro-preview",
      "permission": {
        "context7_*": "allow",
        "exa_*": "allow",
        "gh_grep_*": "allow",
        "webfetch": "allow",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "write": "deny",
        "edit": "deny",
        "bash": {
          "*": "deny",
          "gh *": "allow",
          "npm view*": "allow",
          "pip show*": "allow",
          "man *": "allow",
          "jq *": "allow",
          "rg *": "allow",
          "fd *": "allow"
        }
      }
    },
    "scribe": {
      "model": "minimax/MiniMax-M2.5",
      "permission": {
        "bash": {
          "*": "deny"
        },
        "edit": "allow",
        "glob": "allow",
        "read": "allow",
        "write": "allow"
      }
    },
    "coder": {
      "temperature": 0.1,
      "model": "minimax/MiniMax-M2.7",
      "permission": {
        "context7_*": "deny",
        "exa_*": "deny",
        "gh_grep_*": "deny",
        "read": "allow",
        "write": "allow",
        "edit": "allow",
        "glob": "allow",
        "grep": "allow",
        "bash": "allow"
      }
    },
    "reviewer": {
      "temperature": 0.2,
      "model": "google/antigravity-claude-opus-4-6",
      "permission": {
        "edit": "deny",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "write": "deny",
        "bash": {
          "*": "deny",
          "git diff*": "allow",
          "git log*": "allow",
          "git show*": "allow",
          "git blame*": "allow",
          "rg *": "allow"
        },
        "plan_read": "allow",
        "delegation_read": "allow",
        "delegation_list": "allow"
      }
    },
    "plan": {
      "temperature": 0.3,
      "model": "zai-coding-plan/glm-5",
      "permission": {
        "edit": "deny",
        "write": "deny",
        "bash": {
          "*": "deny"
        },
        "task": "allow",
        "worktree_*": "allow"
      }
    },
    "build": {
      "temperature": 0.2,
      "model": "google/antigravity-claude-sonnet-4-6",
      "permission": {
        "edit": "deny",
        "write": "deny",
        "bash": {
          "*": "deny"
        },
        "task": "allow",
        "worktree_*": "allow"
      }
    }
  },
  "mcp": {
    "MCP_DOCKER": {
      "type": "local",
      "command": ["docker", "mcp", "gateway", "run"],
      "enabled": true
    }
  },
  "provider": {
    "zai-coding-plan": {
      "options": {
        "apiKey": "$Z_AI_API_KEY"
      }
    },
    "minimax": {
      "npm": "@ai-sdk/anthropic",
      "options": {
        "baseURL": "https://api.minimax.io/anthropic/v1",
        "apiKey": "<MINIMAX_API_KEY> (Optional)"
      },
      "models": {
        "MiniMax-M2.5": {
          "name": "MiniMax M2.5"
        },
        "MiniMax-M2.7": {
          "name": "MiniMax M2.7"
        }
      }
    },
    "google": {
      "models": {
        "antigravity-claude-sonnet-4-6": {
          "name": "Claude Sonnet 4.6 (Antigravity)",
          "limit": {
            "context": 200000,
            "output": 64000
          },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"]
          }
        },
        "antigravity-claude-opus-4-6": {
          "name": "Claude Opus 4.6 (Antigravity)",
          "limit": {
            "context": 200000,
            "output": 64000
          },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"]
          }
        },
        "gemini-3.1-flash-lite-preview": {
          "name": "Gemini 3.1 Flash Lite Preview",
          "limit": {
            "context": 1048576,
            "output": 65536
          },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"]
          }
        },
        "gemini-3.1-pro-preview": {
          "name": "Gemini 3.1 Pro Preview",
          "limit": {
            "context": 1048576,
            "output": 65535
          },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"]
          }
        }
      }
    },
    // Edgee adds prompt/token compression for supported upstream models.
    "edgee": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "edgee",
      "options": {
        "baseURL": "https://api.edgee.ai/v1",
        "apiKey": "$EDGEE_API_KEY"
      },
      "models": {
        "mistral-small": {
          "name": "mistral small (edgee)"
        },
        "gpt-4": {
          "name": "gpt-4 (edgee)"
        },
        "claude-3-haiku": {
          "name": "claude 3 haiku (edgee)"
        }
      }
    }
  },
  "model": "zai-coding-plan/glm-5",
  "small_model": "minimax/MiniMax-M2.5",
  "permission": {
    "bash": "allow",
    "task": "deny",
    "context7_*": "allow",
    "exa_*": "allow",
    "gh_grep_*": "allow",
    "kagi_*": "allow",
    "webfetch": "allow",
    "worktree_*": "allow",
    "lsp": "allow",
    "skill": "allow",
    "question": "allow".
    "doom_loop": "deny"
  }
}
