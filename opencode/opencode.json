{
  "$schema": "https://opencode.ai/config.json",
  "model": "kilo-auto/balanced",
  "small_model": "kilo-auto/free",
  "agent": {
    "build": {
      "model": "opencode/minimax-m2.5-free",
      "reasoningEffort": "high",
      "temperature": 0.2
    },
    "coder": {
      "model": "opencode/minimax-m2.5-free",
      "reasoningEffort": "medium",
      "temperature": 0.2
    },
    "explore": {
      "model": "kilo/morph-warp-grep-v2",
      "reasoningEffort": "low",
      "temperature": 0.1
    },
    "plan": {
      "model": "kilo/xiaomi/mimo-v2-pro:free",
      "reasoningEffort": "high",
      "temperature": 0.3
    },
    "researcher": {
      "model": "kilo/z-ai/glm-5",
      "reasoningEffort": "high",
      "temperature": 0.4
    },
    "reviewer": {
      "model": "opencode/minimax-m2.5-free",
      "reasoningEffort": "high",
      "temperature": 0.1
    },
    "scribe": {
      "model": "kilo/arcee-ai/trinity-large-preview:free",
      "reasoningEffort": "low",
      "temperature": 0.7
    }
  },
  "default_agent": "build",
  "instructions": ["AGENTS.md", "https://raw.githubusercontent.com/JRedeker/opencode-shell-strategy/trunk/shell_strategy.md"],
  "mcp": {
    "ref-tools": {
      "type": "remote",
      "url": "https://api.ref.tools/mcp"
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app"
    },
    "icm": {
      "command": ["icm", "serve"],
      "enabled": true,
      "type": "local"
    },
    "context-mode": {
      "type": "local",
      "command": ["context-mode"]
    },
    "cachebro": {
      "type": "local",
      "command": ["bunx", "--bun", "cachebro", "serve"]
    }
  },
  "share": "manual",
  "permission": {
    "*": "allow",
    "sudo *": "deny",
    "rm -rf /": "deny",
    "rm -rf /*": "deny",
    "rm -rf ~": "deny",
    "rm -rf ~/*": "deny",
    ":(){:|:&};:": "deny",
    "doom_loop": "deny"
  },
  "plugin": [
    "opencode-session-handoff@latest",
    "opencode-anthropic-oauth@0.4.1",
    "opencode-gemini-auth@1.4.9",
    "opencode-kilo-auth@1.1.4",
    "@gotgenes/opencode-agent-identity@3.0.1",
    "opencode-ignore@1.1.0",
    "opencode-pty@0.2.3",
    "openslimedit@1.0.4",
    "@spoons-and-mirrors/subtask2@0.3.5",
    "openfundus@0.1.6",
    "opencode-rtk-rewrite",
    "context-mode@latest",
    "opencode-cachebro@latest",
    "opencode-snip@latest",
    "opencode-toolbox@0.10.4",
    "micode",
    "opencode-cross-repo@0.4.1",
    "@tuanhung303/opencode-acp@3.0.15"
  ],
  "lsp": {
    "typescript": {
      "command": ["vtsls", "--stdio"],
      "extensions": [".js", ".jsx", ".ts", ".tsx", ".mjs", ".cjs", ".mts", ".cts"],
      "initialization": {
        "preferences": { "importModuleSpecifierPreference": "relative" }
      }
    },
    "pyright": {
      "command": ["basedpyright-langserver", "--stdio"],
      "extensions": [".py", ".pyw", ".pyi"]
    },
    "rust": {
      "command": ["rust-analyzer"],
      "extensions": [".rs"]
    },
    "bash": {
      "command": ["bash-language-server", "start"],
      "extensions": [".sh", ".bash", ".zsh"]
    },
    "yaml-ls": {
      "command": ["yaml-language-server", "--stdio"],
      "extensions": [".yaml", ".yml"]
    },
    "markdown-oxide": {
      "command": ["markdown-oxide"],
      "extensions": [".md", ".mdx"]
    },
    "json-ls": {
      "command": ["vscode-json-language-server", "--stdio"],
      "extensions": [".json", ".jsonc"]
    },
    "dockerfile-ls": {
      "command": ["docker-langserver", "--stdio"],
      "extensions": [".dockerfile"]
    },
    "html-ls": {
      "command": ["vscode-html-language-server", "--stdio"],
      "extensions": [".html", ".htm"]
    },
    "css-ls": {
      "command": ["vscode-css-language-server", "--stdio"],
      "extensions": [".css", ".scss", ".less"]
    },
    "tombi": {
      "command": ["tombi", "lsp"],
      "extensions": [".toml"]
    }
  },
  "disabled_providers": ["openai"],
  "watcher": { "ignore": ["node_modules/**", "dist/**", ".git/**", ".venv/**"] },
  "provider": {
    "anthropic": {
      "options": {
        "apiKey": "{env:ANTHROPIC_API_KEY}",
        "chunkTimeout": 30000,
        "setCacheKey": true,
        "timeout": 600000
      }
    }
  },
  "experimental": {
    "continue_loop_on_deny": false,
    "mcp_timeout": 10000,
    "openTelemetry": false,
    "batch_tool": true
  }
}
