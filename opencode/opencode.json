{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode/glm-5",
  "small_model": "opencode/minimax-m2.5-free",
  "agent": {
    "build": {
      "model": "openrouter/minimax/minimax-m2.7",
      "reasoningEffort": "high",
      "temperature": 0.3,
      "textVerbosity": "low"
    },
    "coder": {
      "model": "openrouter/minimax/minimax-m2.7",
      "reasoningEffort": "medium",
      "temperature": 0.2,
      "textVerbosity": "low"
    },
    "explore": {
      "model": "opencode/minimax-m2.5-free",
      "reasoningEffort": "low",
      "temperature": 0.2,
      "textVerbosity": "low"
    },
    "plan": {
      "model": "opencode/glm-5",
      "reasoningEffort": "high",
      "temperature": 0.3,
      "textVerbosity": "low"
    },
    "researcher": {
      "model": "opencode/glm-5",
      "reasoningEffort": "high",
      "temperature": 0.4,
      "textVerbosity": "medium"
    },
    "reviewer": {
      "model": "opencode/glm-5",
      "reasoningEffort": "high",
      "temperature": 0.1,
      "textVerbosity": "medium"
    },
    "scribe": {
      "model": "opencode/minimax-m2.5-free",
      "reasoningEffort": "low",
      "temperature": 1,
      "textVerbosity": "high"
    }
  },
  "default_agent": "plan",
  "experimental": {
    "continue_loop_on_deny": false,
    "mcp_timeout": 10000,
    "openTelemetry": false
  },
  "instructions": ["AGENTS.md"],
  "mcp": {
    "ref-tools": {
      "type": "remote",
      "url": "https://api.ref.tools/mcp"
    },
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp?tools=web_search_exa,web_search_advanced_exa,crawling_exa"
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app"
    },
    "icm": {
      "command": [
        "/home/ven0m0/.local/share/mise/installs/cargo-https-github-com-rtk-ai-icm/HEAD/bin/icm",
        "serve"
      ],
      "enabled": true,
      "type": "local"
    },
    "context-mode": {
      "type": "local",
      "command": ["context-mode"]
    },
    "cachebro": {
      "type": "local",
      "command": ["bunx", "--bun", "cachebro", "serve"]
    }
  },
  "model": "openrouter/minimax/minimax-m2.7",
  "permission": {
    "*": "allow",
    "sudo *": "deny",
    "rm -rf /": "deny",
    "rm -rf /*": "deny",
    "rm -rf ~": "deny",
    "rm -rf ~/*": "deny",
    ":(){:|:&};:": "deny",
    "doom_loop": "deny"
  },
  "plugin": [
    "opencode-session-handoff@latest",
    "opencode-anthropic-oauth@0.4.1",
    "opencode-gemini-auth@1.4.9",
    "opencode-kilo-auth@1.1.4",
    "@gotgenes/opencode-agent-identity@3.0.1",
    "opencode-ignore@1.1.0",
    "opencode-pty@0.2.3",
    "openslimedit@1.0.4",
    "@spoons-and-mirrors/subtask2@0.3.5",
    "@azumag/opencode-rate-limit-fallback@1.70.0",
    "openfundus@0.1.6",
    "openrtk@0.1.0",
    "context-mode@latest",
    "opencode-cachebro@latest",
    "opencode-snip@latest",
    "opencode-toolbox@0.10.4"
  ],
  "lsp": {
    "typescript": {
      "command": ["vtsls", "--stdio"],
      "extensions": [".js", ".jsx", ".ts", ".tsx", ".mjs", ".cjs", ".mts", ".cts"],
      "initialization": {
        "preferences": { "importModuleSpecifierPreference": "relative" }
      }
    },
    "pyright": {
      "command": ["basedpyright-langserver", "--stdio"],
      "extensions": [".py", ".pyw", ".pyi"]
    },
    "rust": {
      "command": ["rust-analyzer"],
      "extensions": [".rs"]
    },
    "bash": {
      "command": ["bash-language-server", "start"],
      "extensions": [".sh", ".bash", ".zsh"]
    },
    "yaml-ls": {
      "command": ["yaml-language-server", "--stdio"],
      "extensions": [".yaml", ".yml"]
    },
    "markdown-oxide": {
      "command": ["markdown-oxide"],
      "extensions": [".md", ".mdx"]
    },
    "json-ls": {
      "command": ["vscode-json-language-server", "--stdio"],
      "extensions": [".json", ".jsonc"]
    },
    "dockerfile-ls": {
      "command": ["docker-langserver", "--stdio"],
      "extensions": [".dockerfile"]
    },
    "html-ls": {
      "command": ["vscode-html-language-server", "--stdio"],
      "extensions": [".html", ".htm"]
    },
    "css-ls": {
      "command": ["vscode-css-language-server", "--stdio"],
      "extensions": [".css", ".scss", ".less"]
    },
    "tombi": {
      "command": ["tombi", "lsp"],
      "extensions": [".toml"]
    }
  },
  "disabled_providers": ["openai"],
  "provider": {
    "anthropic": {
      "options": {
        "apiKey": "{env:ANTHROPIC_API_KEY}",
        "chunkTimeout": 30000,
        "setCacheKey": true,
        "timeout": 600000
      }
    }
  },
  "share": "auto",
  "small_model": "kilo/minimax/minimax-m2.5:free",
  "watcher": { "ignore": ["node_modules/**", "dist/**", ".git/**"] }
}
