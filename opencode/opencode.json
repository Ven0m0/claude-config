{
  "$schema": "https://opencode.ai/config.json",
  "model": "kilo-auto/balanced",
  "small_model": "kilo-auto/free",
  "agents": {
    "build": { "model": "opencode/minimax-m2.5-free", "reasoningEffort": "high", "temperature": 0.2 },
    "coder": { "model": "opencode/minimax-m2.5-free", "reasoningEffort": "medium", "temperature": 0.2 },
    "explore": { "model": "kilo/x-ai/grok-4.1-fast", "reasoningEffort": "low", "temperature": 0.1 },
    "plan": { "model": "opencode/mimo-v2-pro-free", "reasoningEffort": "high", "temperature": 0.3 },
    "researcher": { "model": "kilo/z-ai/glm-5", "reasoningEffort": "high", "temperature": 0.4 },
    "reviewer": { "model": "opencode/minimax-m2.5-free", "reasoningEffort": "high", "temperature": 0.1 },
    "scribe": { "model": "kilo/arcee-ai/trinity-large-preview:free", "reasoningEffort": "low", "temperature": 0.7 }
  },
  "default_agent": "build",
  "instructions": [
    "AGENTS.md",
    "https://raw.githubusercontent.com/JRedeker/opencode-shell-strategy/trunk/shell_strategy.md"
  ],
  "mcpServers": {
    "context7": { "type": "sse", "url": "https://mcp.context7.com/mcp" },
    "ref-tools": { "type": "sse", "url": "https://api.ref.tools/mcp" },
    "gh_grep": { "type": "sse", "url": "https://mcp.grep.app" },
    "icm": { "type": "stdio", "command": "icm", "args": ["serve"] },
    "context-mode": { "type": "stdio", "command": "context-mode" }
  },
  "share": "manual",
  "permission": {
    "*": "allow",
    "sudo *": "deny",
    "rm -rf /": "deny",
    "rm -rf /*": "deny",
    "rm -rf ~": "deny",
    "rm -rf ~/*": "deny",
    ":(){:|:&}:": "deny",
    "doom_loop": "deny"
  },
  "plugin": [
    "opencode-anthropic-oauth@0.4.1",
    "opencode-gemini-auth@1.4.9",
    "opencode-kilo-auth@1.1.4",
    "@gotgenes/opencode-agent-identity@3.0.1",
    "opencode-ignore@1.1.0",
    "opencode-pty@0.2.3",
    "openslimedit@1.0.4",
    "@spoons-and-mirrors/subtask2@0.3.5",
    "openfundus@0.1.6",
    "opencode-toolbox@0.10.4",
    "opencode-cross-repo@0.4.1",
    "@tuanhung303/opencode-acp@3.0.15"
  ],
  "lsp": {
    "typescript": {
      "command": "vtsls",
      "args": ["--stdio"],
      "options": { "preferences": { "importModuleSpecifierPreference": "relative" } }
    },
    "pyright": { "command": "basedpyright-langserver", "args": ["--stdio"] },
    "rust": { "command": "rust-analyzer" },
    "bash": { "command": "bash-language-server", "args": ["start"] },
    "yaml-ls": { "command": "yaml-language-server", "args": ["--stdio"] },
    "markdown-oxide": { "command": "markdown-oxide" },
    "json-ls": { "command": "vscode-json-language-server", "args": ["--stdio"] },
    "dockerfile-ls": { "command": "docker-langserver", "args": ["--stdio"] },
    "html-ls": { "command": "vscode-html-language-server", "args": ["--stdio"] },
    "css-ls": { "command": "vscode-css-language-server", "args": ["--stdio"] },
    "tombi": { "command": "tombi", "args": ["lsp"] }
  },
  "disabled_providers": ["openai"],
  "watcher": { "ignore": ["node_modules/**", "dist/**", ".git/**", ".venv/**", ".omc/**", ".kilo/**", ".kilocode/**", ".opencode/**"] },
  "providers": {
    "anthropic": { "apiKey": "{env:ANTHROPIC_API_KEY}", "chunkTimeout": 30000, "setCacheKey": true, "timeout": 600000 }
  },
  "experimental": {
    "continue_loop_on_deny": false,
    "mcp_timeout": 30000,
    "openTelemetry": false,
    "batch_tool": true
  }
}
