{
  "$schema":"https://opencode.ai/config.json",
  "disabled_providers": ["openai"]
  "instructions":[
    "AGENTS.md"
  ],
  "plugin":[
    "@morphllm/opencode-morph-plugin@2.0.7",
    "opencode-pty@latest",
    "opencode-antigravity-auth@latest",
    "opencode-gemini-auth@latest",
    "opencode-session-handoff@latest",
    "opencode-websearch@latest",
    "opencode-ignore@latest"
  ],
  "lsp":{
    "typescript":{
      "command":[
        "typescript-language-server",
        "--stdio"
      ],
      "extensions":[
        ".js",
        ".jsx",
        ".ts",
        ".tsx",
        ".mjs",
        ".cjs",
        ".mts",
        ".cts"
      ],
      "initialization":{
        "preferences":{
          "importModuleSpecifierPreference":"relative"
        }
      }
    },
    "pyright":{
      "command":[
        "pyright-langserver",
        "--stdio"
      ],
      "extensions":[
        ".py",
        ".pyw",
        ".pyi"
      ]
    },
    "rust":{
      "command":[ "rust-analyzer"],
      "extensions":[".rs"]
    },
    "bash":{
      "command":["bash-language-server", "start"],
      "extensions":[".sh", ".bash", ".zsh"]
    },
    "yaml-ls":{
      "command":[
        "yaml-language-server",
        "--stdio"
      ],
      "extensions":[
        ".yaml",
        ".yml"
      ]
    }
  },
  "formatter":{
    "prettier":{
      "command":[
        "prettier",
        "--write",
        "$FILE"
      ],
      "extensions":[
        ".js",
        ".jsx",
        ".ts",
        ".tsx",
        ".json",
        ".jsonc",
        ".md",
        ".css",
        ".scss",
        ".html",
        ".yml",
        ".yaml"
      ]
    },
    "ruff":{
      "command":[
        "uv",
        "tool",
        "run",
        "ruff",
        "format",
        "$FILE"
      ],
      "extensions":[
        ".py",
        ".pyw",
        ".pyi"
      ]
    },
    "rustfmt":{
      "command":[
        "rustfmt",
        "$FILE"
      ],
      "extensions":[
        ".rs"
      ]
    },
    "shfmt":{
      "command":[
        "shfmt",
        "-w",
        "$FILE"
      ],
      "extensions":[
        ".sh",
        ".bash",
        ".zsh"
      ]
    }
  },
  "agent":{
    "explore":{
      "model":"minimax/MiniMax-M2.5",
      "permission":{
        "edit":"deny",
        "read":"allow",
        "glob":"allow",
        "grep":"allow",
        "write":"deny",
        "bash":{
          "*":"deny",
          "ls *":"allow",
          "eza *":"allow",
          "tree *":"allow",
          "rg *":"allow",
          "fd *":"allow",
          "git *":"allow"
        }
      }
    },
    "executor":{
      "model":"minimax/MiniMax-M2.7",
      "permission":{
        "context7_*":"deny",
        "exa_*":"deny",
        "gh_grep_*":"deny",
        "read":"allow",
        "write":"allow",
        "edit":"allow",
        "glob":"allow",
        "grep":"allow",
        "bash":"allow",
        "task":"deny"
      }
    },
    "general":{
      "disable":false
    },
  "mcp":{
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      }
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app"
    }
  },
  "provider":{
    "zai-coding-plan":{
      "options":{
        "apiKey":"${env:Z_AI_API_KEY}"
      }
    },
  "model": "{env:OPENCODE_MODEL}",
  "permission":{
    "bash":"allow",
    "task":"deny",
    "context7_*":"allow",
    "exa_*":"allow",
    "gh_grep_*":"allow",
    "kagi_*":"allow",
    "webfetch":"allow",
    "worktree_*":"allow",
    "lsp":"allow",
    "skill":"allow",
    "question":"allow",
    "doom_loop": "deny"
  }
  }
}
