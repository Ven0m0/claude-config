# Copy this file to .env and fill in values
# NEVER commit .env to version control

# --- Required ---

# Cloudflare API token (create at dash.cloudflare.com/profile/api-tokens)
# Needs permissions: Zone:DNS:Edit, Account:Cloudflare Tunnel:Edit
# Must be an API Token (40 chars). If you only have a Global API Key (37 hex
# chars), also set CLOUDFLARE_EMAIL below.
CLOUDFLARE_API_TOKEN=your_token_here

# Required only if using a Global API Key instead of an API Token:
# CLOUDFLARE_EMAIL=your@cloudflare-account-email.com

# Password to protect the openchamber web UI
UI_PASSWORD=change_me_to_something_secure

# Hostname where openchamber will be accessible
TUNNEL_HOSTNAME=opencode.yourdomain.com

# Name for the Cloudflare tunnel (used as identifier, must be unique per account)
TUNNEL_NAME=openchamber

# --- Install mode ---
# 'local' (default): run as systemd services (no Docker required)
# 'docker':          run via Docker Compose
INSTALL_MODE=local

# Port openchamber listens on (local mode only; Docker uses internal networking)
OPENCHAMBER_PORT=3000

# Use PM2 instead of systemd for local mode (optional)
USE_PM2=false

# --- opencode-container mode (docker-compose.opencode-container.yml) ---
# Required when using opencode-container instead of openchamber.
# Set whichever provider key opencode is configured to use.
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# GITHUB_TOKEN=your_github_personal_access_token_here

# --- Set automatically by setup.sh (do not edit manually) ---
# TUNNEL_TOKEN=
