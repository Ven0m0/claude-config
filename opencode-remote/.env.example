# Copy this file to .env and fill in values
# NEVER commit .env to version control
OPENCODE_ENABLE_EXA=true
OPENCODE_ENABLE_EXPERIMENTAL_MODELS=true
OPENCODE_DISABLE_FILETIME_CHECK=true
OPENCODE_DISABLE_CLAUDE_CODE_PROMPT=true
OPENCODE_EXPERIMENTAL_EXA=true
OPENCODE_EXPERIMENTAL=true
OPENCODE_EXPERIMENTAL_OXFMT=true
OPENCODE_EXPERIMENTAL_LSP_TOOL=true
OPENCODE_EXPERIMENTAL_LSP_TY=true
OPENCODE_EXPERIMENTAL_MARKDOWN=true
OPENCODE_EXPERIMENTAL_PLAN_MODE=true
OPENCODE_EXPERIMENTAL_FILEWATCHER=true
OPENCODE_EXPERIMENTAL_BASH_DEFAULT_TIMEOUT_MS=20000
MORPH_TIMEOUT=60000
MORPH_MODEL=morph-v3-fast
OPENCODE_EXPERIMENTAL_LAZY_TOOLS=true
OPENCODE_PRUNE_SCALE_WITH_CONTEXT=true
# Note: the OPENCODE_* flags above only take effect if forwarded into the
# opencode-manager container's environment in docker-compose.yml (not wired
# in by default).

# --- Required ---

# Cloudflare API token (create at dash.cloudflare.com/profile/api-tokens)
# Needs permissions: Zone:DNS:Edit, Account:Cloudflare Tunnel:Edit
# Must be an API Token (40 chars). If you only have a Global API Key (37 hex
# chars), also set CLOUDFLARE_EMAIL below.
CLOUDFLARE_API_TOKEN=your_token_here

# Required only if using a Global API Key instead of an API Token:
# CLOUDFLARE_EMAIL=your@cloudflare-account-email.com

# opencode-manager auth secret (Better Auth). Generate with:
#   openssl rand -base64 32
AUTH_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_base64_32

# Pre-configured admin account, created on first startup (disables self-signup)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me_to_something_secure

# Set to true to force a password reset from ADMIN_PASSWORD, then remove
# ADMIN_PASSWORD_RESET=false

# Hostname where opencode-manager will be accessible
TUNNEL_HOSTNAME=opencode.yourdomain.com

# Name for the Cloudflare tunnel (used as identifier, must be unique per account)
TUNNEL_NAME=opencode-manager

# AUTH_TRUSTED_ORIGINS and AUTH_SECURE_COOKIES are derived from TUNNEL_HOSTNAME
# in docker-compose.yml - no need to set them here.

# --- Set automatically by setup.sh (do not edit manually) ---
# TUNNEL_TOKEN=
