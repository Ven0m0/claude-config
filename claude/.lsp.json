{
  "$schema": "https://code.claude.com/schemas/lsp.json",
  "_comment": "Language Server Protocol Configuration",
  "bash": {
    "command": "bash-language-server",
    "args": ["start"],
    "extensionToLanguage": {
      ".sh": "shellscript", ".bash": "shellscript",
      ".zsh": "shellscript", ".ksh": "shellscript"
    },
    "transport": "stdio",
    "maxRestarts": 3
  },
  "fish": {
    "command": "fish-lsp",
    "args": ["start"],
    "extensionToLanguage": { ".fish": "fish" },
    "transport": "stdio",
    "maxRestarts": 3
  },
  "python": {
    "command": "basedpyright-langserver",
    "args": ["--stdio"],
    "extensionToLanguage": { ".py": "python", ".pyi": "python" },
    "transport": "stdio",
    "maxRestarts": 3
  },
  "typescript": {
    "command": "vtsls",
    "args": ["--stdio"],
    "extensionToLanguage": {
      ".ts": "typescript", ".tsx": "typescriptreact",
      ".js": "javascript",  ".jsx": "javascriptreact",
      ".mts": "typescript", ".cts": "typescript",
      ".mjs": "javascript", ".cjs": "javascript"
    },
    "transport": "stdio",
    "initializationOptions": {
      "maxTsServerMemory": 4096,
      "disableAutomaticTypeAcquisition": true,
      "preferences": { "disableSuggestions": false },
      "typescript": {
        "tsserver": { "logVerbosity": "normal" }
      }
    },
    "maxRestarts": 3
  },
  "rust": {
    "command": "rust-analyzer",
    "args": [],
    "extensionToLanguage": { ".rs": "rust" },
    "transport": "stdio",
    "maxRestarts": 3
  },
  "toml": {
    "command": "tombi",
    "args": ["lsp"],
    "extensionToLanguage": { ".toml": "toml" },
    "transport": "stdio"
  },
  "json": {
    "command": "vscode-json-language-server",
    "args": ["--stdio"],
    "extensionToLanguage": { ".json": "json", ".jsonc": "jsonc" },
    "transport": "stdio",
    "settings": {
      "json": {
        "validate": { "enable": true },
        "schemas": []
      }
    },
    "maxRestarts": 3
  },
  "yaml": {
    "command": "yaml-language-server",
    "args": ["--stdio"],
    "extensionToLanguage": { ".yaml": "yaml", ".yml": "yaml" },
    "transport": "stdio",
    "settings": {
      "yaml": {
        "validate": true,
        "hover": true,
        "completion": true,
        "schemas": {}
      }
    },
    "maxRestarts": 3
  },
  "html": {
    "command": "vscode-html-language-server",
    "args": ["--stdio"],
    "extensionToLanguage": { ".html": "html", ".htm": "html" },
    "transport": "stdio",
    "maxRestarts": 3
  },
  "css": {
    "command": "vscode-css-language-server",
    "args": ["--stdio"],
    "extensionToLanguage": { ".css": "css", ".scss": "scss", ".less": "less" },
    "transport": "stdio",
    "maxRestarts": 3
  },
  "dockerfile": {
    "command": "dockerfile-language-server-nodejs",
    "args": ["--stdio"],
    "extensionToLanguage": {
      "Dockerfile": "dockerfile", ".dockerfile": "dockerfile"
    },
    "transport": "stdio",
    "maxRestarts": 3
  },
  "markdown-oxide": {
    "command": "markdown-oxide",
    "args": [],
    "extensionToLanguage": { ".md": "markdown" },
    "transport": "stdio"
  }
}
