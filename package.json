{
  "name": "kilo-tools",
  "version": "1.0.0",
  "description": "Git-installable kilo/opencode plugin: hashline edit/read/grep, ast-grep, json-repair, gitingest, context-shield.",
  "main": "kilo-tools/index.ts",
  "scripts": {
    "lint:claude": "claudelint check-all",
    "lint:claude:fix": "claudelint format --fix",
    "lint:biome": "bunx @biomejs/biome check .",
    "lint:biome:fix": "bunx @biomejs/biome check --write .",
    "lint:oxlint": "bunx oxlint .",
    "lint:oxlint:fix": "bunx oxlint --fix .",
    "lint:oxfmt": "bunx oxfmt --check .",
    "lint:oxfmt:fix": "bunx oxfmt ."
  },
  "dependencies": {
    "@ast-grep/cli": "^0.44.0",
    "repair-json-stream": "^1.3.1"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": "*"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@opencode-ai/plugin": "^1.14.33",
    "@types/bun": "*",
    "agnix": "0.37.5",
    "claude-code-lint": "^0.7.0",
    "mitata": "^1.0.34",
    "oxfmt": "0.59.0",
    "oxlint": "1.74.0",
    "ultracite": "^7.4.2"
  }
}
